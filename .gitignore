# =============================================================================
# Reptile Haven — .gitignore
# Stack: Vite + TypeScript + Phaser 3
# =============================================================================

# --- Dependencies ---
node_modules/

# --- Build output ---
dist/
dist-ssr/

# --- Vite cache ---
.vite/
*.local

# --- TypeScript ---
*.tsbuildinfo

# --- Environment files ---
.env
.env.local
.env.*.local

# --- Logs ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- OS generated ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# --- IDE and editors ---
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --- VS Code (keep shared settings, ignore personal ones) ---
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example

# --- Kiro IDE (keep .kiro tracked — it contains specs, hooks, and steering) ---
# .kiro/ is intentionally NOT ignored

# --- Test coverage output ---
coverage/
*.lcov
.nyc_output/

# --- Misc ---
*.pem
